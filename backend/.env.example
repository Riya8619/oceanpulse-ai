APP_NAME=OceanPulse AI
ENVIRONMENT=production

# Get a real key at https://aistudio.google.com/apikey -- it must start with "AIza"
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

NOAA_BASE_URL=https://www.ncei.noaa.gov
NASA_BASE_URL=https://api.nasa.gov

# Comma-separated list of frontend origins allowed to call this API
ALLOWED_ORIGINS=https://your-frontend.onrender.com,http://localhost:5173
