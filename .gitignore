# ── Environment / secrets — never commit real values ──
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# ── Python (backend) ──
backend/venv/
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/

# ── Node / Vite (frontend) ──
node_modules/
frontend/node_modules/
frontend/dist/
dist/
.vite/

# ── Editor / OS ──
.DS_Store
.vscode/
.idea/
*.swp

# ── Logs ──
*.log
npm-debug.log*
